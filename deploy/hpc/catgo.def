# CatGO Apptainer/Singularity Container Definition
#
# Full build: all 5 calculators (EMT, MACE, CHGNet, M3GNet, xTB) + Sella (TS search)
# No PyTorch GPU by default — add --nv at runtime for GPU acceleration.
#
# Build (requires sudo or --fakeroot):
#   sudo apptainer build catgo.sif catgo.def
#
# Expected image size: ~7-9 GB (PyTorch CPU + ML potentials + scientific stack)
#
# Transfer to Expanse:
#   scp catgo.sif $USER@login.expanse.sdsc.edu:~/containers/
#
# Run:
#   See catgo-job.sh for Slurm submission script.

# ================================================================
# Stage 1: Build the SvelteKit static frontend
# ================================================================
Bootstrap: docker
From: node:20-bookworm-slim
Stage: frontend-build

%post
    npm install -g pnpm@9
    mkdir -p /build

%files
    # Copy dependency manifests first (cache-friendly ordering)
    package.json /build/package.json
    pnpm-lock.yaml /build/pnpm-lock.yaml
    # Pre-compiled WASM package (linked as workspace dependency)
    # The link: protocol in package.json expects extensions/rust-wasm/ with its package.json
    extensions/rust-wasm /build/extensions/rust-wasm

%post
    cd /build
    pnpm install --frozen-lockfile

%files
    # Copy source after install so node_modules layer is cached
    src /build/src
    static /build/static
    svelte.config.js /build/svelte.config.js
    vite.config.ts /build/vite.config.ts
    tsconfig.json /build/tsconfig.json
    contributing.md /build/contributing.md
    # vite.config.ts imports this mock (only used in test mode, but import must resolve)
    extensions/vscode/tests/vscode-mock.js /build/extensions/vscode/tests/vscode-mock.js

%post
    cd /build
    # In the container, frontend and backend share the same nginx origin.
    # The frontend must use relative paths (/api/...) so nginx can proxy them.
    # We set SERVER_PORT to a value vite will use, but the key trick is that
    # the user accesses CatGO through nginx (port 8080) which proxies /api/*
    # to the backend. We build with a matching port so the dev define works,
    # but at runtime all traffic goes through nginx on one port.
    export SERVER_PORT=8080
    export NODE_OPTIONS="--max-old-space-size=4096"
    pnpm build
    # Verify build output exists
    test -f /build/build/index.html || (echo "ERROR: SvelteKit build failed" && exit 1)


# ================================================================
# Stage 2: Runtime image (Python + nginx, no Node.js)
# ================================================================
Bootstrap: docker
From: python:3.11-slim-bookworm
Stage: runtime

%labels
    Author CatGO Team
    Description CatGO materials science visualization toolkit for HPC
    Version 0.3.0
    org.opencontainers.image.source https://github.com/janosh/catgo

%files from frontend-build
    /build/build /opt/catgo/frontend

%files
    server /opt/catgo/server

%post
    # --- System dependencies (gcc/g++/gfortran needed to compile CHGNet, tblite, etc.) ---
    # liblapack-dev + libopenblas-dev needed by tblite (xTB)
    apt-get update && apt-get install -y --no-install-recommends \
        nginx \
        gcc \
        g++ \
        gfortran \
        python3-dev \
        cmake \
        pkg-config \
        liblapack-dev \
        libopenblas-dev \
        git \
        && rm -rf /var/lib/apt/lists/*

    # --- Python dependencies (all 5 calculators + Sella) ---
    # Install PyTorch CPU-only first (smaller than full CUDA build)
    pip install --no-cache-dir \
        torch --index-url https://download.pytorch.org/whl/cpu

    # Core server dependencies
    pip install --no-cache-dir \
        "fastapi>=0.109.0" \
        "uvicorn[standard]>=0.27.0" \
        "pydantic>=2.0.0" \
        "python-multipart>=0.0.6" \
        "httpx>=0.27.0" \
        "asyncssh>=2.14.0" \
        "numpy>=1.24.0" \
        "scipy>=1.10.0" \
        "ase>=3.22.0" \
        "pymatgen>=2024.1.0" \
        "mdtraj>=1.9.9" \
        "scikit-learn>=1.3.0" \
        "umap-learn>=0.5.0"

    # ML potentials
    pip install --no-cache-dir "mace-torch>=0.3.0"    # MACE universal potential
    pip install --no-cache-dir "chgnet>=0.3.0"         # CHGNet GNN potential
    pip install --no-cache-dir "matgl>=1.0.0"          # M3GNet via MatGL

    # Semi-empirical (xTB)
    # tblite provides GFN2-xTB, GFN1-xTB, GFN0-xTB, GFN-FF, IPEA1-xTB
    pip install --no-cache-dir "tblite[ase]>=0.3.0"

    # Sella (transition state search + IRC)
    # Requires --no-build-isolation due to setuptools-scm dependency
    pip install --no-cache-dir setuptools-scm
    pip install --no-cache-dir --no-build-isolation "sella>=2.3.0"

    # --- Create runtime directories ---
    mkdir -p /var/log/catgo /run/nginx /opt/catgo/data

    # --- Verify critical imports (fail build if any missing) ---
    python -c "import fastapi; print(f'FastAPI {fastapi.__version__}')"
    python -c "import ase; print(f'ASE {ase.__version__}')"
    python -c "from importlib.metadata import version; print(f'pymatgen {version(\"pymatgen\")}')"
    python -c "from mace.calculators import mace_mp; print('MACE: OK')"
    python -c "from chgnet.model import CHGNet; print('CHGNet: OK')"
    python -c "import matgl; print(f'MatGL {matgl.__version__} (M3GNet): OK')"
    python -c "from tblite.ase import TBLite; print('tblite (xTB): OK')"
    python -c "from sella import Sella, IRC; print('Sella: OK')"

%environment
    export CATGO_FRONTEND_DIR=/opt/catgo/frontend
    export CATGO_DATA_DIR=/opt/catgo/data
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8
    # Default ports (overridable via SINGULARITYENV_*)
    export CATGO_FRONTEND_PORT=8080
    export CATGO_BACKEND_PORT=8000
    # Force MACE to CPU unless --nv is used
    export MACE_DEVICE=cpu

%startscript
    #!/bin/bash
    PORT_FE="${CATGO_FRONTEND_PORT:-8080}"
    PORT_BE="${CATGO_BACKEND_PORT:-8000}"

    echo "============================================"
    echo "CatGO Materials Science Toolkit"
    echo "  Frontend: http://0.0.0.0:${PORT_FE}"
    echo "  Backend:  http://127.0.0.1:${PORT_BE} (proxied)"
    echo "============================================"

    # Start FastAPI backend
    cd /opt/catgo/server
    export SERVER_PORT="$PORT_BE"
    uvicorn main:app \
        --host 127.0.0.1 \
        --port "$PORT_BE" \
        --workers 1 \
        --log-level info &
    BACKEND_PID=$!

    # Wait briefly for backend to start
    sleep 2

    # Generate nginx config
    cat > /tmp/nginx-catgo.conf <<NGINX_CONF
worker_processes 1;
error_log /var/log/catgo/nginx-error.log warn;
pid /tmp/nginx.pid;

events {
    worker_connections 128;
}

http {
    include /etc/nginx/mime.types;
    default_type application/octet-stream;
    access_log /var/log/catgo/nginx-access.log;
    sendfile on;

    # Temp paths writable without root
    client_body_temp_path /tmp/nginx_client_body;
    proxy_temp_path /tmp/nginx_proxy;
    fastcgi_temp_path /tmp/nginx_fastcgi;
    uwsgi_temp_path /tmp/nginx_uwsgi;
    scgi_temp_path /tmp/nginx_scgi;

    server {
        listen ${PORT_FE};
        root /opt/catgo/frontend;
        index index.html;

        # SPA fallback — serve index.html for client-side routes
        location / {
            try_files \$uri \$uri/ /index.html;
        }

        # Proxy REST API to FastAPI backend
        location /api/ {
            proxy_pass http://127.0.0.1:${PORT_BE};
            proxy_http_version 1.1;
            proxy_set_header Host \$host;
            proxy_set_header X-Real-IP \$remote_addr;
            proxy_read_timeout 600s;
            # WebSocket upgrade for /api/optimize/ws etc.
            proxy_set_header Upgrade \$http_upgrade;
            proxy_set_header Connection "upgrade";
        }

        # WASM files: correct MIME type + SharedArrayBuffer headers
        location ~* \.wasm\$ {
            types { application/wasm wasm; }
            add_header Cross-Origin-Opener-Policy same-origin;
            add_header Cross-Origin-Embedder-Policy require-corp;
        }

        # Cache static assets
        location ~* \.(js|css|png|jpg|svg|ico|woff2?)\$ {
            expires 7d;
            add_header Cache-Control "public, immutable";
        }
    }
}
NGINX_CONF

    nginx -c /tmp/nginx-catgo.conf -g "daemon off;" &
    NGINX_PID=$!

    # Handle shutdown
    trap "kill $BACKEND_PID $NGINX_PID 2>/dev/null; exit 0" SIGTERM SIGINT

    echo "CatGO ready. Frontend: :${PORT_FE}  Backend: :${PORT_BE}"
    wait $BACKEND_PID $NGINX_PID

%runscript
    #!/bin/bash
    echo "CatGO Materials Science Toolkit v0.3.0"
    echo ""
    echo "Usage:"
    echo "  singularity instance start catgo.sif catgo    # Start as service"
    echo "  singularity instance stop catgo                # Stop service"
    echo ""
    echo "  # Or run backend directly:"
    echo "  singularity exec catgo.sif python /opt/catgo/server/main.py"
    echo ""
    echo "Installed calculators: EMT (built-in), MACE, CHGNet, M3GNet, xTB"
    echo "Installed optimizers:  BFGS, Sella (TS Search, Minimize, IRC)"
    echo ""
    echo "Environment variables:"
    echo "  CATGO_FRONTEND_PORT  (default: 8080)"
    echo "  CATGO_BACKEND_PORT   (default: 8000)"
    echo "  MACE_DEVICE          (default: cpu, set to cuda with --nv)"
    exec "$@"

%test
    echo "=== CatGO Container Validation ==="
    python --version

    # Core deps
    python -c "import fastapi; print(f'  FastAPI {fastapi.__version__}')"
    python -c "import uvicorn; print(f'  Uvicorn {uvicorn.__version__}')"
    python -c "import ase; print(f'  ASE {ase.__version__}')"
    python -c "import pymatgen; print(f'  Pymatgen OK')"
    python -c "import numpy; print(f'  NumPy {numpy.__version__}')"
    python -c "import scipy; print(f'  SciPy {scipy.__version__}')"

    # ML potentials
    python -c "from mace.calculators import mace_mp; print('  MACE: OK')"
    python -c "from chgnet.model import CHGNet; print('  CHGNet: OK')"
    python -c "import matgl; print(f'  MatGL {matgl.__version__} (M3GNet): OK')"

    # Semi-empirical
    python -c "from tblite.ase import TBLite; print('  tblite (xTB): OK')"

    # TS search
    python -c "from sella import Sella, IRC; print('  Sella: OK')"

    # Frontend build
    test -f /opt/catgo/frontend/index.html && echo "  Frontend build: OK" || echo "  Frontend build: MISSING"

    # Server entry point
    test -f /opt/catgo/server/main.py && echo "  Backend server: OK" || echo "  Backend server: MISSING"

    echo "=== Validation complete ==="

%help
    CatGO - Interactive Visualization Toolkit for Materials Science
    ================================================================

    This container packages the CatGO web application for deployment
    on HPC systems (tested on SDSC Expanse).

    Included components:
      - Static SvelteKit frontend (served via nginx)
      - FastAPI Python backend (uvicorn)
      - ASE, pymatgen for atomistic modeling
      - 5 calculators: EMT, MACE, CHGNet, M3GNet, xTB
      - Sella for transition state search and IRC

    Quick start:
      singularity instance start \
        --bind /path/to/data:/opt/catgo/data \
        catgo.sif catgo

    For GPU acceleration (MACE, CHGNet, M3GNet):
      export SINGULARITYENV_MACE_DEVICE=cuda
      singularity instance start --nv \
        --bind /path/to/data:/opt/catgo/data \
        catgo.sif catgo

    Access via SSH tunnel:
      ssh -L 8080:<compute-node>:8080 user@login.expanse.sdsc.edu
      Then open http://localhost:8080

    See deploy/hpc/catgo-job.sh for a complete Slurm submission script.
