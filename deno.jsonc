{
  "tasks": {
    "dev": "deno run -A --node-modules-dir npm:vite dev",
    "build": "deno run -A --node-modules-dir npm:vite build",
    "preview": "deno run -A --node-modules-dir npm:vite preview",
    "serve": "deno task build && deno task preview",
    "test": "deno task vitest && deno task e2e",
    "vitest": "deno run -A --node-modules-dir npm:vitest",
    "e2e": "npx playwright test",
    "test:install": "npx playwright install chromium",
    "package": "svelte-package && rm src/site/state.svelte.d.ts",
    "prepublishOnly": "deno task package",
    "changelog": "deno run -A https://github.com/janosh/workflows/raw/refs/heads/main/scripts/make-release-notes.ts"
  },
  "lock": false,
  "imports": {
    "$lib": "./src/lib",
    "$lib/": "./src/lib/",
    "$site": "./src/site",
    "$site/": "./src/site/"
  },
  "lint": {
    "exclude": [
      "build-desktop/**",
      "src/scripts/**",
      "src/lib/structure/ferrox.d.ts",
      "src/lib/structure/ferrox.js",
      "src/lib/structure/ferrox_bg.js",
      "src/lib/structure/ferrox_bg.wasm.d.ts",
      "extensions/rust-wasm/pkg/**"
    ],
    "rules": {
      "tags": ["recommended"],
      "include": [
        "ban-unused-ignore",
        "jsx-key",
        "jsx-no-duplicate-props",
        "jsx-no-useless-fragment",
        "no-async-promise-executor",
        // "no-boolean-literal-for-arguments", // TODO only disable this in test files or even just for .toBe(true)
        "no-const-assign",
        "no-eval",
        "no-self-compare",
        "no-sparse-arrays",
        "no-sync-fn-in-async-fn",
        "no-throw-literal",
        "no-useless-rename"
      ],
      "exclude": [
        // Style preferences inherited from MatterViz upstream — large
        // diff to fix across files, suppressed pending a dedicated cleanup
        // pass.
        "default-param-last",
        "eqeqeq",
        "guard-for-in",
        "no-control-regex",
        "no-empty",
        "no-inner-declarations",
        "no-regex-spaces",
        "no-sloppy-imports",
        "no-await-in-loop",
        "no-explicit-any",
        "no-non-null-assertion",
        "no-non-null-asserted-optional-chain",
        "no-unused-vars",
        "prefer-const",
        "require-await",
        "single-var-declarator",
        "no-window",
        "no-window-prefix",
        "no-process-global"
      ]
    }
  },
  "fmt": {
    "exclude": [
      "build-desktop/**",
      "CLAUDE.md",
      "src/site/structures/*.json",
      "src/site/molecules/*.json",
      "src/site/trajectories/*.json",
      "tests/vitest/fixtures/xrd/*.json",
      "src/site/phonons/*.json",
      "src/lib/structure/ferrox.d.ts",
      "src/lib/structure/ferrox.js",
      "src/lib/structure/ferrox_bg.js",
      "src/lib/structure/ferrox_bg.wasm.d.ts",
      "extensions/rust-wasm/pkg/**",
      "**/*.svelte",
      "src/routes/**/*.md",
      "**/*.yaml",
      "**/*.yml",
      "tmp"
    ],
    "indentWidth": 2,
    "lineWidth": 90,
    "semiColons": false,
    "singleQuote": true,
    "proseWrap": "preserve"
  },
  "unstable": ["fmt-component", "sloppy-imports"],
  "compilerOptions": {
    "lib": ["dom", "esnext"]
  },
  "nodeModulesDir": "manual"
}
